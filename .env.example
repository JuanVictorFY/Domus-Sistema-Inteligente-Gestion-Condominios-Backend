# =============================================
# DOMUS BACKEND — Variables de Entorno
# =============================================
# Copia este archivo como .env y completa los valores

# === SERVIDOR ===
PORT=3000
NODE_ENV=development

# === BASE DE DATOS (PostgreSQL) ===
# Ejemplo: Neon, Supabase, Railway, Render Postgres
DATABASE_URL="postgresql://usuario:password@host:5432/domus_db?sslmode=require"

# === AUTENTICACION JWT ===
# Genera una clave segura con: openssl rand -base64 64
JWT_SECRET=cambia_esto_por_una_clave_secreta_segura
JWT_EXPIRY=24h

# === FRONTEND ===
# URL del frontend para configurar CORS en produccion
FRONTEND_URL=https://tu-frontend.onrender.com

# === EMAIL (Resend) ===
# Obtén tu API key en https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email del administrador principal (receptor de formularios de contacto)
ADMIN_EMAIL=admin.domus.condominio@gmail.com
